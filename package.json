{
  "name": "miniature-guacamole",
  "version": "1.0.0",
  "description": "an Apple Music web player built with Next.js and MusicKit",
  "main": "now.json",
  "repository": "https://github.com/mcansh/miniature-guacamole",
  "author": "Logan McAnsh <logan@mcan.sh> (https://mcan.sh)",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=12.x"
  },
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc",
    "lint": "eslint ./ --ext .js,.ts,.tsx",
    "lint:css": "stylelint './**/*.js' './**/*.jsx' './**/*.tsx' './**/*.ts'",
    "test": "jest",
    "format": "prettier --write \"**/*.+(js|jsx|json|yml|yaml|css|less|scss|ts|tsx|md|graphql|mdx)\"",
    "validate": "npm-run-all --parallel lint lint:css format type-check test"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "scripts/ts-precommit",
      "yarn lint:css",
      "git add"
    ]
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "1.2.26",
    "@fortawesome/free-solid-svg-icons": "5.12.0",
    "@fortawesome/react-fontawesome": "0.1.8",
    "@mcansh/next-now-base-url": "1.2.0",
    "@next/plugin-sentry": "9.1.6",
    "@sentry/browser": "5.10.2",
    "@svgr/webpack": "4.3.3",
    "@zeit/next-source-maps": "0.0.4-canary.1",
    "babel-plugin-styled-components": "1.10.6",
    "date-fns": "2.8.1",
    "isomorphic-unfetch": "3.0.0",
    "jsonwebtoken": "8.5.1",
    "next": "9.1.7-canary.1",
    "next-offline": "4.0.6",
    "nookies": "2.0.8",
    "polished": "3.4.2",
    "react": "16.12.0",
    "react-dom": "16.12.0",
    "react-simple-img": "2.3.8",
    "styled-components": "5.0.0-beta.3",
    "swr": "0.1.15",
    "type-fest": "0.8.1"
  },
  "devDependencies": {
    "@mcansh/eslint-config": "2.4.0",
    "@testing-library/jest-dom": "4.2.4",
    "@testing-library/react": "9.4.0",
    "@types/jest": "24.0.24",
    "@types/jsonwebtoken": "8.3.5",
    "@types/react": "16.9.17",
    "@types/react-dom": "16.9.4",
    "@types/react-no-ssr": "1.1.1",
    "@types/styled-components": "4.4.1",
    "@typescript-eslint/eslint-plugin": "2.12.0",
    "@typescript-eslint/parser": "2.12.0",
    "dotenv": "8.2.0",
    "eslint": "6.7.2",
    "eslint-config-airbnb": "18.0.1",
    "eslint-config-kentcdodds": "14.7.0",
    "eslint-config-prettier": "6.7.0",
    "eslint-import-resolver-typescript": "2.0.0",
    "eslint-plugin-import": "2.19.1",
    "eslint-plugin-prettier": "3.1.2",
    "eslint-plugin-you-dont-need-lodash-underscore": "6.8.0",
    "husky": "3.1.0",
    "jest": "24.9.0",
    "lint-staged": "9.5.0",
    "npm-run-all": "4.1.5",
    "prettier": "1.19.1",
    "stylelint": "12.0.0",
    "stylelint-config-prettier": "8.0.0",
    "stylelint-config-recommended": "3.0.0",
    "stylelint-config-styled-components": "0.1.1",
    "stylelint-prettier": "1.1.2",
    "typescript": "3.7.3"
  }
}
